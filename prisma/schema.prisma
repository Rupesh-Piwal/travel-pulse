generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUMS
//////////////////////

enum Budget {
  BUDGET
  MID
  LUXURY
}

enum Vibe {
  ADVENTURE
  RELAXED
  FOODIE
  CULTURAL
}

enum ItineraryStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum TransactionReason {
  SIGNUP
  PURCHASE
  GENERATION
  EXPORT
  REFUND
}

enum SubscriptionPlan {
  EXPLORER
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
}

enum JobStatus {
  QUEUED
  ACTIVE
  COMPLETED
  FAILED
}

enum JobType {
  ITINERARY
  PDF_EXPORT
}

//////////////////////
// MODELS
//////////////////////

model User {
  id               String  @id @default(cuid())
  email            String? @unique
  name             String?
  avatarUrl        String?
  image            String?
  emailVerified    DateTime?
  stripeCustomerId String?

  createdAt DateTime @default(now())

  // relations
  accounts      Account[]
  sessions      Session[]
  credits       Credit?
  transactions  CreditTransaction[]
  itineraries   Itinerary[]
  wishlistItems WishlistItem[]
  subscription  Subscription?
  jobs          Job[]
  pdfExports    PdfExport[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//////////////////////

model Credit {
  id      String @id @default(cuid())
  userId  String @unique
  balance Int    @default(0)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

//////////////////////

model CreditTransaction {
  id          String            @id @default(cuid())
  userId      String
  amount      Int
  reason      TransactionReason
  referenceId String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

//////////////////////

model Itinerary {
  id     String @id @default(cuid())
  userId String

  destination String
  days        Int
  budget      Budget
  vibe        Vibe

  status ItineraryStatus @default(QUEUED)

  data Json?

  // ⭐ NEW FIELD
  lastUsedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pdfExports PdfExport[]

  @@index([userId])
  @@index([status])
}

//////////////////////

model WishlistItem {
  id     String @id @default(cuid())
  userId String

  destination String
  photoUrl    String

  sortOrder Int

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

//////////////////////

model Subscription {
  id     String @id @default(cuid())
  userId String @unique

  stripeSubscriptionId String
  plan                 SubscriptionPlan
  status               SubscriptionStatus

  currentPeriodEnd DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//////////////////////
// ⭐ NEW: JOBS TABLE
//////////////////////

model Job {
  id        String   @id @default(cuid())
  userId    String

  type      JobType
  status    JobStatus @default(QUEUED)

  referenceId String? // itineraryId or pdfExportId

  error     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

//////////////////////
// ⭐ NEW: PDF EXPORTS
//////////////////////

model PdfExport {
  id          String   @id @default(cuid())
  userId      String
  itineraryId String

  url         String?
  status      JobStatus @default(QUEUED)

  expiresAt   DateTime?

  createdAt   DateTime @default(now())

  user       User      @relation(fields: [userId], references: [id])
  itinerary  Itinerary @relation(fields: [itineraryId], references: [id])

  @@index([userId])
  @@index([itineraryId])
}

//////////////////////
// DESTINATIONS & ACTIVITIES
//////////////////////

model Destination {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  tags        String[]
  lat         Float
  lng         Float

  activities  Activity[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Activity {
  id            String   @id @default(cuid())
  destinationId String
  title         String
  description   String
  image         String?
  lat           Float
  lng           Float
  duration      Int      @default(60) // in minutes
  vibe          Vibe

  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  updatedAt     DateTime @updatedAt

  @@index([destinationId])
}